{
  "name": "slooze-eats",
  "private": true,
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "build": "npm run prisma:generate && npm run build --workspaces && rm -rf .next && cp -r apps/web/.next . && cp -r apps/web/public . || true",
    "prisma:generate": "npx prisma generate --schema=apps/api/prisma/schema.prisma"
  },
  "dependencies": {
    "@prisma/client": "^7.5.0",
    "next": "^15.1.6",
    "prisma": "^7.5.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "optionalDependencies": {
    "@next/swc-linux-x64-gnu": "15.1.6",
    "@next/swc-linux-x64-musl": "15.1.6",
    "@tailwindcss/oxide-linux-x64-gnu": "4.0.0",
    "lightningcss-linux-x64-gnu": "1.32.0"
  }
}
