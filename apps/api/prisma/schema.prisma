// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}


model User {
  id             String          @id @default(uuid())
  name           String
  email          String          @unique
  password       String
  role           Role
  country        Country
  orders         Order[]
  paymentMethods PaymentMethod[]
  sharedCarts    SharedCartParticipant[]
  createdAt      DateTime        @default(now())
}

model Restaurant {
  id        String     @id @default(uuid())
  name      String
  cuisine   String
  image     String?
  rating    Float      @default(4.0)
  country   Country
  menuItems MenuItem[]
  orders    Order[]
  sharedCarts SharedCart[]
}

model MenuItem {
  id           String      @id @default(uuid())
  name         String
  description  String?
  price        Float
  image        String?
  category     String
  restaurant   Restaurant  @relation(fields: [restaurantId], references: [id])
  restaurantId String
  orderItems   OrderItem[]
  sharedCartItems SharedCartItem[]
}

model Order {
  id              String        @id @default(uuid())
  status          OrderStatus   @default(PENDING)
  totalAmount     Float         @default(0)
  user            User          @relation(fields: [userId], references: [id])
  userId          String
  restaurant      Restaurant    @relation(fields: [restaurantId], references: [id])
  restaurantId    String
  items           OrderItem[]
  paymentMethod   PaymentMethod? @relation(fields: [paymentMethodId], references: [id])
  paymentMethodId String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
}

model OrderItem {
  id         String   @id @default(uuid())
  quantity   Int
  price      Float
  order      Order    @relation(fields: [orderId], references: [id])
  orderId    String
  menuItem   MenuItem @relation(fields: [menuItemId], references: [id])
  menuItemId String
}

model PaymentMethod {
  id        String   @id @default(uuid())
  type      CardType
  last4     String
  name      String
  user      User     @relation(fields: [userId], references: [id])
  userId    String
  isDefault Boolean  @default(false)
  orders    Order[]
  createdAt DateTime @default(now())
}

enum Role {
  ADMIN
  MANAGER
  MEMBER
}

enum Country {
  INDIA
  AMERICA
}

enum OrderStatus {
  PENDING
  CONFIRMED
  CANCELLED
}

enum CardType {
  VISA
  MASTERCARD
  AMEX
}

model SharedCart {
  id           String     @id @default(uuid())
  restaurantId String
  country      Country
  isActive     Boolean    @default(true)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  restaurant   Restaurant @relation(fields: [restaurantId], references: [id])
  participants SharedCartParticipant[]
  items        SharedCartItem[]
}

model SharedCartParticipant {
  id           String     @id @default(uuid())
  cartId       String
  userId       String
  joinedAt     DateTime   @default(now())

  cart         SharedCart @relation(fields: [cartId], references: [id], onDelete: Cascade)
  user         User       @relation(fields: [userId], references: [id])

  @@unique([cartId, userId])
}

model SharedCartItem {
  id           String     @id @default(uuid())
  cartId       String
  menuItemId   String
  quantity     Int

  cart         SharedCart @relation(fields: [cartId], references: [id], onDelete: Cascade)
  menuItem     MenuItem   @relation(fields: [menuItemId], references: [id])

  @@unique([cartId, menuItemId])
}
